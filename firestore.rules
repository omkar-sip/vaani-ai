rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read and write their OWN top-level document
    match /users/{uid} {
      allow read, write: if request.auth != null
                         && request.auth.uid == uid;
    }

    // Users can read and write their own subcollections (sessions, companionLog, profile, etc.)
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null
                         && request.auth.uid == uid;
    }

    // Analytics events: any authenticated user can create, any authenticated user can read
    // (admin filtering is done client-side; tighten this to custom claims for production)
    match /analyticsEvents/{eventId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
